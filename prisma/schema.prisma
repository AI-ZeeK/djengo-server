// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
  output          = "../node_modules/@internal/prisma-main"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["profiles", "platform", "communications", "roles", "media_files", "financials", "general", "addresses_and_contacts", "organizations"]
}

model PlatformStaff {
  platform_staff_id String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id           String   @db.Uuid
  role_id           Int
  is_active         Boolean? @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user User         @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  role PlatformRole @relation(fields: [role_id], references: [role_id], onDelete: Cascade)

  @@map("platform_staff")
  @@schema("platform")
}

model PlatformRole {
  role_id     Int      @id @default(autoincrement())
  role_name   String?  @unique @db.VarChar(50) // e.g., Super Admin, Admin
  description String?  @default("")
  is_active   Boolean? @default(true)

  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @updatedAt @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)

  platform_staff            PlatformStaff[]
  platform_role_permissions PlatformRolePermission[]

  @@index([role_name], map: "idx_platform_roles_role_name")
  @@map("platform_roles")
  @@schema("platform")
}

model PlatformPermission {
  permission_id Int     @id @default(autoincrement())
  permission    String  @unique @db.VarChar(50) // e.g., manage_users, manage_settings
  description   String? @default("")

  role_permissions PlatformRolePermission[]

  @@map("platform_permissions")
  @@schema("platform")
}

model PlatformRolePermission {
  role_id       Int
  permission_id Int

  role       PlatformRole       @relation(fields: [role_id], references: [role_id], onDelete: Cascade)
  permission PlatformPermission @relation(fields: [permission_id], references: [permission_id], onDelete: Cascade)

  @@id([role_id, permission_id])
  @@map("platform_role_permissions")
  @@schema("platform")
}

model Role {
  role_id     Int      @id @default(autoincrement())
  role_name   String?  @unique @db.VarChar(50)
  description String?  @default("")
  is_active   Boolean? @default(true)

  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @updatedAt @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)

  user_roles UserRole[]

  @@index([role_name], map: "idx_roles_role_name")
  @@map("roles")
  @@schema("roles")
}

model UserRole {
  user_id   String  @db.Uuid
  role_name String  @default("")
  is_active Boolean @default(false)

  user User @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  role Role @relation(fields: [role_name], references: [role_name], onDelete: Cascade)

  @@id([user_id, role_name])
  @@unique([user_id, is_active])
  @@map("user_roles")
  @@schema("roles")
}

model User {
  user_id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  first_name          String?  @default("") @db.VarChar(50)
  last_name           String?  @default("") @db.VarChar(50)
  password            String?  @default("")
  date_of_birth       DateTime @default(now())
  email               String   @unique @db.VarChar(255)
  phone_number        String?  @unique @db.VarChar(20)
  backup_phone_number String?  @unique @db.VarChar(20)
  email_verified      Boolean? @default(false)
  phone_verified      Boolean? @default(false)
  kyc_verified        Boolean? @default(false)
  is_blocked          Boolean? @default(false)
  fcm_token           String   @default("")
  refresh_token       String   @default("")
  is_online           Boolean? @default(false)

  deleted_at DateTime? @db.Timestamptz(6)
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @updatedAt @db.Timestamptz(6)

  uploaded_files        Files[]
  receiver_transactions Transaction[]        @relation("receiver_transactions")
  sender_transactions   Transaction[]        @relation("sender_transactions")
  staff                 Staff[]
  reservations          Reservation[]
  verifications         Verification[]
  platform_staff        PlatformStaff[]
  user_roles            UserRole[]
  message               Message[]
  user_companies        UserCompany[]
  read_receipts         MessageRead[]
  chat_participants     ChatParticipant[]
  unread_message_counts UnreadMessageCount[]
  push_subscriptions    PushSubscription[]

  @@index([email], map: "idx_users_email")
  @@index([phone_number], map: "idx_users_phone_number")
  @@map("users")
  @@schema("profiles")
}

model Staff {
  staff_id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id       String?  @db.Uuid
  date_joined      DateTime @default(now())
  user_id          String   @db.Uuid
  role_id          String?  @db.Uuid
  department_id    String?  @db.Uuid
  designation      String?
  profile_complete Boolean  @default(false)
  payroll_active   Boolean  @default(true)
  staff_active     Boolean  @default(true)

  user       User        @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  company    Company?    @relation(fields: [company_id], references: [company_id], onDelete: SetNull)
  department Department? @relation(fields: [department_id], references: [department_id], onDelete: SetNull)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  probations    StaffProbation[]
  payment_info  StaffPaymentInformation?
  payroll_staff PayrollStaff[]
  company_roles CompanyRole[]

  @@map("staff")
  @@schema("profiles")
}

model StaffProbation {
  staff_probabtion_id Int       @id @default(autoincrement())
  probation_starts_at DateTime?
  probation_ends_at   DateTime?
  probation_salary    Int?
  staff_id            String    @db.Uuid

  probation_status SituationStatus @default(INACTIVE)

  staff Staff @relation(fields: [staff_id], references: [staff_id], onDelete: Cascade)

  @@map("staff_probation_info")
  @@schema("profiles")
}

model StaffPaymentInformation {
  staff_id            String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  salary_amount       Int     @default(0)
  bank_name           String? @default("")
  bank_code           String? @default("")
  bank_account_number String? @default("")

  payment_schedule PaymentSchedule @default(MONTHLY)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  staff Staff @relation(fields: [staff_id], references: [staff_id], onDelete: Cascade)

  @@map("staff_payment_information")
  @@schema("profiles")
}

model UserCompany {
  user_company_id String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id         String  @db.Uuid
  company_id      String  @db.Uuid
  is_primary      Boolean @default(false)
  is_owner        Boolean @default(false)

  user    User    @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  company Company @relation(fields: [company_id], references: [company_id], onDelete: Cascade)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([user_id, company_id])
  @@map("user_companies")
  @@schema("organizations")
}

model Company {
  company_id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_ref         String?   @unique @db.VarChar(255)
  company_name        String?   @db.VarChar(50)
  email               String?   @unique @db.VarChar(255)
  phone_number        String?   @unique @db.VarChar(20)
  backup_phone_number String?   @db.VarChar(20)
  registeration_date  DateTime? @db.Timestamptz(6)
  registration_number String?   @db.VarChar(50)
  email_verified      Boolean?  @default(false)
  phone_verified      Boolean?  @default(false)
  deleted_at          DateTime? @db.Timestamptz(6)
  multi_branch        Boolean?  @default(false)

  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @updatedAt @db.Timestamptz(6)

  transactions      Transaction[]
  staff             Staff[]
  departments       Department[]
  payroll_schedules PayrollSchedule[]
  hotels            Hotel[]
  restaurants       Restaurant[]
  global_reports    GlobalReport[]
  Branch            Branch[]
  compsny_roles     CompanyRole[]
  user_companies    UserCompany[]

  @@map("company")
  @@schema("organizations")
}

model CompanyRole {
  role_id       String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id    String  @db.Uuid
  name          String  @default("")
  slug          String  @default("")
  description   String?
  is_active     Boolean @default(true)
  is_global     Boolean @default(false)
  branch_id     String? @db.Uuid
  department_id String? @db.Uuid
  level_number  Int     @default(0)
  reports_to    String? @db.Uuid

  company      Company       @relation(fields: [company_id], references: [company_id], onDelete: Cascade)
  branch       Branch?       @relation(fields: [branch_id], references: [branch_id])
  department   Department?   @relation(fields: [department_id], references: [department_id])
  superior     CompanyRole?  @relation("CompanyRoleHierarchy", fields: [reports_to], references: [role_id])
  subordinates CompanyRole[] @relation("CompanyRoleHierarchy")

  staff Staff[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([company_id, slug, branch_id, department_id])
  @@map("company_roles")
  @@schema("organizations")
}

model Department {
  department_id   String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  department_name String  @db.VarChar(50)
  description     String? @default("")
  company_id      String  @db.Uuid

  company Company @relation(fields: [company_id], references: [company_id], onDelete: Cascade)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  staff         Staff[]
  company_roles CompanyRole[]

  @@unique([company_id, department_name])
  @@map("departments")
  @@schema("organizations")
}

model Hotel {
  hotel_id     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hotel_name   String   @db.VarChar(100)
  company_id   String   @db.Uuid
  total_floors Int
  total_rooms  Int
  is_active    Boolean? @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  company     Company       @relation(fields: [company_id], references: [company_id])
  branches    Branch[]
  HotelReport HotelReport[]
  Room        Room[]

  @@map("hotels")
  @@schema("organizations")
}

model Branch {
  branch_id     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branch_name   String   @db.VarChar(100)
  company_id    String   @db.Uuid
  hotel_id      String?  @db.Uuid
  restaurant_id String?  @db.Uuid
  is_active     Boolean? @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  company        Company        @relation(fields: [company_id], references: [company_id])
  hotel          Hotel?         @relation(fields: [hotel_id], references: [hotel_id])
  restaurant     Restaurant?    @relation(fields: [restaurant_id], references: [restaurant_id])
  rooms          Room[]
  tables         Table[]
  reservations   Reservation[]
  company_roles  CompanyRole[]
  branch_reports BranchReport[]

  @@map("branches")
  @@schema("organizations")
}

model Verification {
  verification_id String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id         String              @db.Uuid
  otp_code        String              @db.VarChar(6) // 6-digit OTP
  purpose         VerificationPurpose
  expires_at      DateTime

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user User @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@index([user_id, purpose], map: "idx_verification_user_purpose")
  @@map("verifications")
  @@schema("profiles")
}

enum VerificationPurpose {
  EMAIL_VERIFICATION
  PHONE_VERIFICATION
  PASSWORD_RESET
  TWO_FACTOR_AUTH

  @@schema("profiles")
}

model BranchReport {
  report_id      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branch_id      String   @db.Uuid
  report_date    DateTime
  occupancy_rate Decimal
  total_revenue  Decimal

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  branch Branch @relation(fields: [branch_id], references: [branch_id])

  @@map("branch_reports")
  @@schema("financials")
}

model GlobalReport {
  report_id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id           String   @db.Uuid
  report_date          DateTime
  total_occupancy_rate Decimal
  total_revenue        Decimal

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  company Company @relation(fields: [company_id], references: [company_id])

  @@map("global_reports")
  @@schema("financials")
}

model Reservation {
  reservation_id String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String            @db.Uuid
  branch_id      String            @db.Uuid
  room_id        String?           @db.Uuid
  table_id       String?           @db.Uuid
  start_time     DateTime
  end_time       DateTime
  status         ReservationStatus @default(PENDING)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user   User   @relation(fields: [user_id], references: [user_id])
  branch Branch @relation(fields: [branch_id], references: [branch_id])
  room   Room?  @relation(fields: [room_id], references: [room_id])
  table  Table? @relation(fields: [table_id], references: [table_id])

  @@map("reservations")
  @@schema("organizations")
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED

  @@schema("organizations")
}

model Room {
  room_id      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  room_number  String   @db.VarChar(10)
  room_type_id String   @db.Uuid
  hotel_id     String   @db.Uuid
  is_available Boolean? @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  room_type    RoomType      @relation(fields: [room_type_id], references: [room_type_id])
  hotel        Hotel         @relation(fields: [hotel_id], references: [hotel_id])
  reservations Reservation[]
  Branch       Branch[]

  @@map("rooms")
  @@schema("organizations")
}

model RoomType {
  room_type_id    String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  room_type_name  String  @db.VarChar(50)
  description     String?
  price_per_night Decimal

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  rooms Room[]

  @@map("room_types")
  @@schema("organizations")
}

model Restaurant {
  restaurant_id   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  restaurant_name String   @db.VarChar(100)
  company_id      String   @db.Uuid
  total_tables    Int
  is_active       Boolean? @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  company          Company            @relation(fields: [company_id], references: [company_id])
  branches         Branch[]
  RestaurantReport RestaurantReport[]
  Table            Table[]

  @@map("restaurants")
  @@schema("organizations")
}

model Table {
  table_id      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  table_number  String   @db.VarChar(10)
  table_type_id String   @db.Uuid
  restaurant_id String   @db.Uuid
  is_available  Boolean? @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  table_type   TableType     @relation(fields: [table_type_id], references: [table_type_id])
  restaurant   Restaurant    @relation(fields: [restaurant_id], references: [restaurant_id])
  reservations Reservation[]
  Branch       Branch[]

  @@map("tables")
  @@schema("organizations")
}

model TableType {
  table_type_id   String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  table_type_name String  @db.VarChar(50)
  description     String?
  capacity        Int

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tables Table[]

  @@map("table_types")
  @@schema("organizations")
}

model HotelReport {
  report_id      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hotel_id       String   @db.Uuid
  report_date    DateTime
  occupancy_rate Decimal
  total_revenue  Decimal

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  hotel Hotel @relation(fields: [hotel_id], references: [hotel_id])

  @@map("hotel_reports")
  @@schema("financials")
}

model RestaurantReport {
  report_id      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  restaurant_id  String   @db.Uuid
  report_date    DateTime
  occupancy_rate Decimal
  total_revenue  Decimal

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurant_id], references: [restaurant_id])

  @@map("restaurant_reports")
  @@schema("financials")
}

model Address {
  address_id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  label                      String?  @default("main") @db.VarChar(50)
  is_default                 Boolean? @default(true)
  is_active                  Boolean? @default(true)
  street                     String?  @db.VarChar(100)
  building                   String?  @db.VarChar(50)
  apartment                  String?  @db.VarChar(25)
  district                   String?  @db.VarChar(50)
  landmark                   String?  @db.VarChar(100)
  instruction_enter_building String?  @db.VarChar(100)
  city                       String?  @db.VarChar(50)
  state                      String?  @db.VarChar(50)
  postal_code                String?  @db.VarChar(20)
  country                    String?  @db.VarChar(50)
  latitude                   Decimal? @db.Decimal(9, 6)
  longitude                  Decimal? @db.Decimal(9, 6)
  direction_url              String   @default("")
  entity_id                  String   @db.Uuid

  deleted_at     DateTime? @db.Timestamptz(6)
  created_at     DateTime? @default(now()) @db.Timestamptz(6)
  updated_at     DateTime? @default(now()) @updatedAt @db.Timestamptz(6)
  entity_type_id Int

  entity_type AddressEntity @relation(fields: [entity_type_id], references: [entity_type_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_addresses_entity_type")

  @@unique([entity_type_id, entity_id, label], map: "addresses_entity_type_entity_id_label_idx")
  @@index([city])
  @@index([country])
  @@index([entity_type_id])
  @@index([entity_type_id], map: "idx_addresses_entity_type_id")
  @@map("addresses")
  @@schema("addresses_and_contacts")
}

model AddressEntity {
  entity_type_id           Int      @id @default(autoincrement())
  entity_type              String   @unique @db.VarChar(50)
  description              String?
  max_addresses_per_entity Int?
  is_active                Boolean? @default(true)

  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @updatedAt @db.Timestamptz(6)

  addresses Address[]

  @@index([entity_type], map: "idx_address_entity_types_entity_type")
  @@map("address_entity_types")
  @@schema("addresses_and_contacts")
}

model Chat {
  chat_id               String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                  String?              @db.VarChar(100)
  chat_type             ChatType             @default(DIRECT)
  created_at            DateTime             @default(now()) @db.Timestamptz(6)
  updated_at            DateTime             @updatedAt @db.Timestamptz(6)
  deleted_at            DateTime?            @db.Timestamptz(6)
  status                ChatStatus           @default(PENDING)
  // Relationships
  messages              Message[]
  participants          ChatParticipant[]
  unread_message_counts UnreadMessageCount[]

  @@map("chats")
  @@schema("communications")
}

enum ChatStatus {
  READ
  DELIVERED
  PENDING
  SENT

  @@schema("communications")
}

model ChatParticipant {
  chat_id      String    @db.Uuid
  user_id      String    @db.Uuid
  joined_at    DateTime  @default(now()) @db.Timestamptz(6)
  is_admin     Boolean   @default(false)
  is_active    Boolean   @default(true)
  left_at      DateTime? @db.Timestamptz(6)
  unread_count Int       @default(0)

  // Relationships
  chat Chat @relation(fields: [chat_id], references: [chat_id], onDelete: Cascade)
  user User @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@id([chat_id, user_id])
  @@map("chat_participants")
  @@schema("communications")
}

model Message {
  message_id String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  chat_id    String        @db.Uuid
  sender_id  String        @db.Uuid
  content    String
  type       MessageType   @default(TEXT)
  status     MessageStatus @default(SENT)
  created_at DateTime      @default(now()) @db.Timestamptz(6)
  updated_at DateTime      @updatedAt @db.Timestamptz(6)
  deleted_at DateTime?     @db.Timestamptz(6)

  // For audio messages
  duration Int? // Duration in seconds

  // For file/image messages
  file_url  String?
  file_size Int?
  file_type String?

  // Relationships
  chat          Chat          @relation(fields: [chat_id], references: [chat_id], onDelete: Cascade)
  sender        User          @relation(fields: [sender_id], references: [user_id], onDelete: Cascade)
  read_receipts MessageRead[]

  @@index([chat_id])
  @@index([sender_id])
  @@map("messages")
  @@schema("communications")
}

model MessageRead {
  message_id String    @db.Uuid
  user_id    String    @db.Uuid
  read_at    DateTime? @db.Timestamptz(6)

  // Relationships
  message Message @relation(fields: [message_id], references: [message_id], onDelete: Cascade)
  user    User    @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@id([message_id, user_id])
  @@map("message_reads")
  @@schema("communications")
}

enum MessageType {
  TEXT
  IMAGE
  AUDIO
  VIDEO
  FILE
  LOCATION
  SYSTEM

  @@schema("communications")
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ

  @@schema("communications")
}

model UnreadMessageCount {
  user_id      String   @db.Uuid
  chat_id      String   @db.Uuid
  count        Int      @default(0)
  last_read_at DateTime @default(now()) @db.Timestamptz(6)

  // Relationships
  user User @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  chat Chat @relation(fields: [chat_id], references: [chat_id], onDelete: Cascade)

  @@id([user_id, chat_id])
  @@map("unread_message_counts")
  @@schema("communications")
}

model Payroll {
  payroll_id   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schedule_id  String    @unique @db.Uuid
  completed_at DateTime?

  status PayrollStatus @default(PENDING)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  schedule PayrollSchedule @relation(fields: [schedule_id], references: [schedule_id])

  payroll_staff PayrollStaff[]

  @@map("payrolls")
  @@schema("financials")
}

model PayrollSchedule {
  schedule_id  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String   @default("")
  company_id   String   @db.Uuid
  scheduled_at DateTime
  month        Int
  year         Int

  status SituationStatus @default(INACTIVE)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  payroll Payroll?
  company Company  @relation(fields: [company_id], references: [company_id])

  @@map("payroll_schedule")
  @@schema("financials")
}

model PayrollStaff {
  payroll_staff_id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  staff_id         String @db.Uuid
  payroll_id       String @db.Uuid
  amount           Int

  status PayrollStatus @default(INPROGRESS)

  staff   Staff   @relation(fields: [staff_id], references: [staff_id])
  payroll Payroll @relation(fields: [payroll_id], references: [payroll_id])

  @@map("payroll_staff")
  @@schema("financials")
}

model Currency {
  currency_code String   @id @db.VarChar(10)
  currency_name String   @unique
  is_active     Boolean? @default(true)

  exchange_rates ExchangeRate[]
  transactions   Transaction[]

  @@map("currencies")
  @@schema("financials")
}

model ExchangeRate {
  id            Int      @id @default(autoincrement())
  base_currency String   @default("USD")
  currency_code String   @unique @db.VarChar(10)
  rate_to_usd   Decimal
  last_updated  DateTime @updatedAt

  currency Currency @relation(fields: [currency_code], references: [currency_code])

  @@map("exchange_rates")
  @@schema("financials")
}

model TransactionType {
  type_id     Int      @id @default(autoincrement())
  type_name   String   @unique @db.VarChar(50)
  description String?
  is_active   Boolean? @default(true)
  category_id Int?

  deleted_at DateTime? @db.Timestamptz(6)
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)

  category Category? @relation(fields: [category_id], references: [type_id], onDelete: NoAction, onUpdate: NoAction)

  Transaction Transaction[]

  @@index([type_name], map: "idx_transaction_types_type_name")
  @@map("transaction_types")
  @@schema("financials")
}

model Category {
  type_id     Int      @id @default(autoincrement())
  type_name   String   @unique @db.VarChar(50)
  description String?
  is_active   Boolean? @default(true)

  deleted_at DateTime? @db.Timestamptz(6)
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)

  transaction_types TransactionType[]

  @@index([type_name], map: "idx_category_types_type_name")
  @@map("categories")
  @@schema("financials")
}

model Transaction {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  amount_usd       Decimal
  specification    String            @db.VarChar(255)
  transaction_ref  String?           @unique
  status           TransactionStatus @default(PENDING)
  currency_code    String            @db.VarChar(10)
  exchange_rate    Decimal
  amount_converted Decimal

  receiver_user_id    String?   @db.Uuid
  company_id          String?   @db.Uuid
  sender_user_id      String?   @db.Uuid
  transaction_type_id Int?      @map("transaction_type_id")
  created_at          DateTime  @default(now()) @db.Timestamptz(6)
  completed_at        DateTime?

  transaction_type TransactionType? @relation(fields: [transaction_type_id], references: [type_id], onDelete: NoAction, onUpdate: NoAction)
  receiver_user    User?            @relation("receiver_transactions", fields: [receiver_user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  sender_user      User?            @relation("sender_transactions", fields: [sender_user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  company          Company?         @relation(fields: [company_id], references: [company_id], onDelete: NoAction, onUpdate: NoAction)
  currency         Currency         @relation(fields: [currency_code], references: [currency_code])

  @@map("transactions")
  @@schema("financials")
}

model FileEntityType {
  entity_type_id       Int      @id @default(autoincrement())
  entity_type          String   @unique @db.VarChar(50)
  description          String?
  max_file_size        Int?
  allowed_mime_types   String[]
  max_files_per_entity Int?
  is_active            Boolean? @default(true)

  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @updatedAt @db.Timestamptz(6)

  files Files[]

  @@index([entity_type], map: "idx_file_entity_types_entity_type")
  @@map("file_entity_types")
  @@schema("media_files")
}

model Files {
  file_id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  file_url            String?
  file_type           String?
  file_size           Int?
  description         String?   @db.VarChar(50)
  uploaded_at         DateTime? @default(now()) @db.Timestamptz(6)
  uploaded_by_user_id String?   @db.Uuid
  entity_id           String    @db.Uuid
  entity_type_id      Int

  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)

  entity_type      FileEntityType @relation(fields: [entity_type_id], references: [entity_type_id])
  uploaded_by_user User?          @relation(fields: [uploaded_by_user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)

  @@index([entity_type_id])
  @@index([entity_type_id], map: "idx_files_entity_type_id")
  @@index([uploaded_by_user_id], map: "idx_files_uploaded_by_user_id")
  @@map("files")
  @@schema("media_files")
}

enum TransactionStatus {
  PENDING
  FAILED
  COMPLETED

  @@schema("financials")
}

enum SituationStatus {
  ACTIVE
  INACTIVE

  @@schema("general")
}

enum PaymentSchedule {
  WEEKLY
  MONTHLY

  @@schema("general")
}

enum PayrollStatus {
  PENDING
  INPROGRESS
  COMPLETED
  FAILED

  @@schema("general")
}

enum ChatType {
  DIRECT
  GROUP
  CHANNEL

  @@schema("communications")
}

model PushSubscription {
  subscription_id String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id         String   @db.Uuid
  endpoint        String
  p256dh          String?
  auth            String?
  platform        String // "WEB", "ANDROID", "IOS"
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  user User @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@unique([user_id, endpoint])
  @@index([user_id])
  @@map("push_subscriptions")
  @@schema("communications")
}
